#include <stdio.h>
#include <string.h>

int modInverse(int a) {
    for(int i=1;i<26;i++)
        if((a*i)%26==1)
            return i;
    return -1;
}

int main() {
    char cipher[100];
    int a = 7, b = 25;
    int a_inv = modInverse(a);

    printf("Enter ciphertext (uppercase): ");
    scanf("%s", cipher);

    for(int i=0; cipher[i]!='\0'; i++) {
        cipher[i] = (a_inv * ((cipher[i]-'A' - b + 26)%26))%26 + 'A';
    }

    printf("Decrypted text: %s\n", cipher);
    return 0;
}
