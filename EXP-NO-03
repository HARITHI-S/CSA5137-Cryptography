#include <stdio.h>
#include <string.h>
#include <ctype.h>

char matrix[5][5];

void generateMatrix(char *key) {
    int used[26] = {0};
    int i, j = 0, k = 0;

    for(i = 0; key[i] != '\0'; i++) {
        char c = toupper(key[i]);
        if(c == 'J') c = 'I';
        if(!used[c - 'A']) {
            matrix[j][k++] = c;
            used[c - 'A'] = 1;
            if(k == 5) { j++; k = 0; }
        }
    }

    for(i = 0; i < 26; i++) {
        if(i + 'A' == 'J') continue;
        if(!used[i]) {
            matrix[j][k++] = i + 'A';
            if(k == 5) { j++; k = 0; }
        }
    }
}

int main() {
    char key[50];
    int i,j;

    printf("Enter key: ");
    scanf("%s", key);

    generateMatrix(key);

    printf("Playfair Matrix:\n");
    for(i=0;i<5;i++) {
        for(j=0;j<5;j++)
            printf("%c ", matrix[i][j]);
        printf("\n");
    }

    return 0;
}
